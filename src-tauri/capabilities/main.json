{
    "$schema": "../gen/schemas/desktop-capability.json",
    "identifier": "main-capability",
    "description": "Capability for the main window to run sidecars",
    "windows": [
        "main"
    ],
    "permissions": [
        "core:default",
        {
            "identifier": "shell:allow-spawn",
            "allow": [
                {
                    "name": "binaries/rb-backend",
                    "sidecar": true
                }
            ]
        },
        "shell:allow-execute"
    ]
}
{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Music Library Manager",
    "version": "0.1.1",
    "identifier": "com.librarymanagement.system",
    "build": {
        "beforeDevCommand": "npm run dev:full",
        "beforeBuildCommand": "npm run build",
        "devUrl": "http://127.0.0.1:5173",
        "frontendDist": "../frontend/dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "label": "main",
                "title": "Music Library Manager",
                "width": 1400,
                "height": 900,
                "resizable": true,
                "visible": false
            },
            {
                "label": "splashscreen",
                "title": "Loading...",
                "url": "splashscreen.html",
                "width": 450,
                "height": 300,
                "decorations": false,
                "resizable": false,
                "center": true,
                "transparent": true,
                "visible": true
            }
        ]
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "externalBin": [
            "binaries/RB_Backend"
        ]
    }
}
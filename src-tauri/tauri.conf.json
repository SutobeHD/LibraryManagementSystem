{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "RB Editor Pro",
    "version": "0.1.0",
    "identifier": "com.rbeditor.pro",
    "build": {
        "beforeDevCommand": "npm run dev:full",
        "beforeBuildCommand": "npm run build",
        "devUrl": "http://127.0.0.1:5173",
        "frontendDist": "../frontend/dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "label": "main",
                "title": "Rekordbox Editor Pro",
                "width": 1400,
                "height": 900,
                "resizable": true,
                "visible": true
            }
        ]
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "externalBin": [
            "binaries/RB_Backend"
        ]
    }
}
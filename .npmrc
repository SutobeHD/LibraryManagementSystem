# --- Security Defaults (Schicht A) ---
# Reference: SLSA Level 2, npm hardening 2026 best practices

# CRITICAL: Disable postinstall/preinstall scripts
# Blocks ~80% of supply-chain malware (lottie-player, ua-parser-js, chalk-style hijacks)
# Re-enable per-package via --foreground-scripts if a known-safe dep needs it
ignore-scripts=true

# Force exact versions on install (no caret/tilde drift)
save-exact=true

# Fail builds on high+ vulnerabilities
audit-level=high

# Disable funding messages (noise reduction)
fund=false

# Disable update notifier (reduces network calls)
update-notifier=false

# Use only the lockfile, no resolution from registry on install
prefer-offline=true

# Strict engine matching (Node version pinning)
engine-strict=true

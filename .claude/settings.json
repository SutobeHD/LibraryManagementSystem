{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(npm audit*)",
      "Bash(npm ls*)",
      "Bash(npm outdated)",
      "Bash(npm view *)",
      "Bash(npx --yes lockfile-lint*)",
      "Bash(npx prettier*)",
      "Bash(npx vitest*)",
      "Bash(node *)",

      "Bash(python -m app.*)",
      "Bash(python -m pip list)",
      "Bash(python -m pip show *)",
      "Bash(python -m venv *)",
      "Bash(python -c *)",
      "Bash(pip install -r requirements.txt)",
      "Bash(pytest*)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(black *)",

      "Bash(cargo check*)",
      "Bash(cargo build*)",
      "Bash(cargo test*)",
      "Bash(cargo fmt*)",
      "Bash(cargo clippy*)",
      "Bash(cargo tree*)",
      "Bash(cargo metadata*)",
      "Bash(rustc --version)",
      "Bash(rustup *)",

      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(git restore *)",
      "Bash(git stash*)",
      "Bash(git remote -v)",
      "Bash(git rev-parse*)",
      "Bash(git ls-files*)",
      "Bash(git blame*)",
      "Bash(git commit -m *)",
      "Bash(git commit -m*)",
      "Bash(git fetch*)",
      "Bash(git pull --ff-only*)",
      "Bash(git checkout -b *)",
      "Bash(git switch *)",
      "Bash(git switch -c *)",
      "Bash(git push)",
      "Bash(git push origin)",
      "Bash(git push origin main)",
      "Bash(git push origin HEAD)",
      "Bash(git push origin *:*)",
      "Bash(git push -u *)",
      "Bash(git push --set-upstream *)",
      "Bash(git revert *)",
      "Bash(git rebase --exec * origin/main)",
      "Bash(git rebase origin/main --exec *)",
      "Bash(git config user.email *)",
      "Bash(git config user.name *)",

      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh api repos/*)",
      "Bash(gh repo view*)",
      "Bash(gh release list*)",
      "Bash(gh release view*)",

      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(file *)",
      "Bash(which *)",
      "Bash(where *)",
      "Bash(echo *)",
      "Bash(curl http://127.0.0.1:*)",
      "Bash(curl http://localhost:*)",

      "Bash(./scripts/security-audit.sh)",
      "Bash(./scripts/security-audit.ps1)",
      "Bash(powershell -File scripts/*)",
      "Bash(powershell -Command Get-Process*)",
      "Bash(powershell -Command Get-NetTCPConnection*)",

      "Read(//**)",
      "Edit(//**)",
      "Write(//**)",
      "Glob(//**)",
      "Grep(//**)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rm -rf /)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard origin/main)",
      "Bash(git reset --hard origin/master)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D*)",
      "Bash(git commit --amend*)",
      "Bash(git rebase -i*)",
      "Bash(npm publish*)",
      "Bash(cargo publish*)",
      "Bash(gh release create*)",
      "Bash(gh release delete*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr close*)",
      "Bash(gh repo delete*)",
      "Bash(gh repo archive*)",
      "Bash(*--no-verify*)",
      "Bash(*--no-gpg-sign*)",
      "Bash(git rebase --root*)",

      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./.credentials)",
      "Read(./.secrets)",
      "Read(./.keys/**)",
      "Edit(./.env)",
      "Edit(./.env.local)",
      "Write(./.env)",
      "Write(./.env.local)",

      "Read(**/music/**)",
      "Edit(**/music/**)",
      "Write(**/music/**)",
      "Read(**/backups/**)",
      "Edit(**/backups/**)",
      "Read(**/exports/**)",
      "Edit(**/exports/**)",
      "Read(**/master.db)",
      "Edit(**/master.db)",
      "Write(**/master.db)"
    ],
    "ask": [
      "Bash(git merge*)",
      "Bash(git rebase -i*)",
      "Bash(git rebase main*)",
      "Bash(git rebase origin/*)",
      "Bash(git cherry-pick*)",
      "Bash(git tag*)",
      "Bash(git pull)",
      "Bash(git pull origin*)",
      "Bash(npm install --save*)",
      "Bash(npm install --save-dev*)",
      "Bash(pip install*)",
      "Bash(cargo add*)",
      "Bash(cargo remove*)",
      "Bash(gh pr create*)",
      "Bash(gh issue create*)"
    ]
  },
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1"
  },
  "outputStyle": "default",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": [".claude/hooks/format-on-edit.py"]
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": [".claude/hooks/auto-push-after-commit.py"]
          }
        ]
      }
    ]
  }
}

{
  "$comment": "Named server definitions consumed by mcp__Claude_Preview__preview_start. Format is repo-internal — confirmed by docs/e2e-testing.md.",
  "version": "0.0.1",
  "configurations": [
    { "name": "frontend", "runtimeExecutable": "npm", "runtimeArgs": ["run", "dev", "--prefix", "frontend"], "port": 5173 },
    { "name": "backend", "runtimeExecutable": "python", "runtimeArgs": ["-m", "app.main"], "port": 8000 }
  ],
  "servers": [
    {
      "name": "backend",
      "command": "python",
      "args": ["-m", "app.main"],
      "cwd": ".",
      "url": "http://127.0.0.1:8000",
      "healthEndpoint": "/api/system/health",
      "readyTimeoutMs": 30000,
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONDONTWRITEBYTECODE": "1"
      }
    },
    {
      "name": "frontend",
      "command": "npm",
      "args": ["run", "dev", "--prefix", "frontend"],
      "cwd": ".",
      "url": "http://localhost:5173",
      "readyTimeoutMs": 60000,
      "env": {
        "BROWSER": "none"
      }
    }
  ]
}
